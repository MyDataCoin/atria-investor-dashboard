# VITE_API_BASE_URL: Base URL of the deployed Atria backend API.
# Everything up to (but not including) "/api/v1". Example: https://api.atria.kg
# Exposed to the browser by Vite because of the VITE_ prefix.
# Copy this value into .env.local (gitignored) to override per-machine.
VITE_API_BASE_URL=https://atria-api.eaysdev.online

# VITE_TICKETS_API: escape hatch for the support help desk.
# Default (unset/1) -> tickets route to the shared backend /support/* endpoints,
#                      so the investor desk and the admin panel see the same threads.
# 0/false           -> force per-browser localStorage (offline demos only; NOT
#                      visible to admins). Contract: docs/support-tickets-api.md.
VITE_TICKETS_API=1

# Dev-only auto-login (see src/api/dev-auth.js). In dev the dashboard signs in as
# the test investor on every reload via the hardcoded OTP flow — no token to paste,
# nothing to keep in sync. Ignored entirely in production builds. All optional:
# VITE_DEV_PHONE=+996770535395
# VITE_DEV_OTP_CODE=111111
# VITE_DEV_AUTOLOGIN=0   # disable auto-login
